# Copy this file to `.env` and fill in your keys.
# .env is gitignored — never commit your real key.

EODHD_API_KEY=your_eodhd_api_key_here

# If you add other providers later (Polygon, Finnhub, IEX, etc.), put their
# keys here too. The provider classes read them via os.environ.
# POLYGON_API_KEY=
# FINNHUB_API_KEY=
